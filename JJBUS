<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>실시간 버스 도착 정보</title>
    <style>
        body { font-family: 'Malgun Gothic', sans-serif; padding: 20px; background-color: #f4f4f9; margin: 0; }
        .header { text-align: center; margin-bottom: 20px; }
        .bus-card { background: white; padding: 18px; margin-bottom: 12px; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
        .bus-no { font-size: 1.4em; font-weight: bold; color: #0056b3; margin-bottom: 5px; }
        .time { font-size: 1.2em; font-weight: bold; color: #d9534f; }
        .desc { font-size: 0.9em; color: #666; }
        .status { text-align: center; color: #666; margin-top: 40px; font-size: 1.1em; }
    </style>
</head>
<body>
    <div class="header">
        <h2>실시간 버스 도착 정보</h2>
    </div>
    <div id="bus-list">
        <div class="status">데이터를 불러오는 중입니다... 🚌</div>
    </div>

    <script>
        // 1. URL에서 파라미터 가져오기 (QR코드에 심어둘 데이터)
        // 예시 URL: https://내도메인.com/index.html?cityCode=37010&nodeId=CAB285000405
        const urlParams = new URLSearchParams(window.location.search);
        const cityCode = urlParams.get('cityCode'); // 도시코드 (전주시는 보통 37010)
        const nodeId = urlParams.get('nodeId');     // 정류소 고유 ID

        // ★ 2. 여기에 공공데이터포털에서 발급받은 '일반 인증키(Encoding)'를 입력하세요 ★
        const API_KEY = 't9yHXe0IuySpaV%2B0KVuffZG5OsMQt8hsEUiJQ8F0DofWzMlEoGFkf5BQCMvPrPJiJRfi5Uqkoksc3MHbuuFkMQ%3D%3D';

        async function fetchBusInfo() {
            const listDiv = document.getElementById('bus-list');

            if (!cityCode || !nodeId) {
                listDiv.innerHTML = '<div class="status">QR 코드가 유효하지 않습니다.<br>(정류소 정보가 없습니다)</div>';
                return;
            }

            // 국토교통부_정류소별도착예정정보 API URL
            const url = `http://apis.data.go.kr/1613000/ArvlInfoInqireService/getSttnAcctoArvlPrearngeInfoList?serviceKey=${API_KEY}&cityCode=${cityCode}&nodeId=${nodeId}&_type=json&numOfRows=10&pageNo=1`;

            try {
                const response = await fetch(url);
                const data = await response.json();

                // API 응답 구조에서 데이터 추출
                const items = data.response?.body?.items?.item;
                listDiv.innerHTML = ''; // 로딩 메시지 지우기

                if (!items) {
                    listDiv.innerHTML = '<div class="status">현재 도착 예정인 버스가 없습니다.</div>';
                    return;
                }

                // 결과가 1개일 경우 객체로 오고, 여러 개일 경우 배열로 오므로 배열로 통일
                const busArray = Array.isArray(items) ? items : [items];

                // 버스 정보를 화면에 카드 형태로 생성
                busArray.forEach(bus => {
                    const min = Math.floor(bus.arrtime / 60); // 초를 분으로 변환
                    const card = document.createElement('div');
                    card.className = 'bus-card';
                    card.innerHTML = `
                        <div class="bus-no">${bus.routeno}번 버스</div>
                        <div class="time">${min}분 후 도착 예정</div>
                        <div class="desc">${bus.arrprevstationcnt}번째 전 정류소 출발</div>
                    `;
                    listDiv.appendChild(card);
                });

            } catch (error) {
                console.error(error);
                listDiv.innerHTML = `<div class="status">데이터를 불러오는 데 실패했습니다.<br>API 키나 네트워크를 확인해주세요.</div>`;
            }
        }

        fetchBusInfo();
    </script>
</body>
</html>
